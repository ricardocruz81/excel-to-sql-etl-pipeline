-- ============================================================
-- 04_validation_stored_procs.sql
-- Validates staging data and promotes clean rows to production
-- ============================================================

USE PropertyETL;
GO

-- -------------------------------------------------------
-- usp_ValidateAndLoadProperties
-- -------------------------------------------------------
CREATE OR ALTER PROCEDURE etl.usp_ValidateAndLoadProperties
    @BatchID UNIQUEIDENTIFIER
AS
BEGIN
    SET NOCOUNT ON;

    -- Mark invalid records
    UPDATE stg.Properties
    SET StgStatus = 'REJECTED'
    WHERE BatchID = @BatchID
      AND (
          TRY_CAST(PropertyID AS INT) IS NULL
          OR PropertyName IS NULL OR LEN(LTRIM(RTRIM(PropertyName))) = 0
          OR Address1 IS NULL OR LEN(LTRIM(RTRIM(Address1))) = 0
          OR Town IS NULL
          OR PostCode IS NULL
          OR PostCode NOT LIKE '[A-Z][A-Z0-9]%[0-9][A-Z][A-Z]'  -- Basic UK postcode
      );

    -- Mark valid records
    UPDATE stg.Properties
    SET StgStatus = 'VALID'
    WHERE BatchID = @BatchID
      AND StgStatus = 'PENDING';

    -- Upsert valid records into production
    MERGE dbo.Properties AS target
    USING (
        SELECT
            CAST(PropertyID AS INT)         AS PropertyID,
            LTRIM(RTRIM(PropertyName))      AS PropertyName,
            LTRIM(RTRIM(PropertyType))      AS PropertyType,
            LTRIM(RTRIM(Address1))          AS Address1,
            LTRIM(RTRIM(Address2))          AS Address2,
            LTRIM(RTRIM(Town))              AS Town,
            UPPER(LTRIM(RTRIM(PostCode)))   AS PostCode,
            TRY_CAST(Bedrooms AS TINYINT)   AS Bedrooms,
            CASE WHEN UPPER(IsVoid) IN ('TRUE','YES','1') THEN 1 ELSE 0 END AS IsVoid
        FROM stg.Properties
        WHERE BatchID = @BatchID AND StgStatus = 'VALID'
    ) AS source ON target.PropertyID = source.PropertyID
    WHEN MATCHED THEN
        UPDATE SET
            PropertyName  = source.PropertyName,
            PropertyType  = source.PropertyType,
            Address1      = source.Address1,
            Address2      = source.Address2,
            Town          = source.Town,
            PostCode      = source.PostCode,
            Bedrooms      = source.Bedrooms,
            IsVoid        = source.IsVoid,
            ModifiedDate  = GETDATE()
    WHEN NOT MATCHED THEN
        INSERT (PropertyID, PropertyName, PropertyType, Address1, Address2, Town, PostCode, Bedrooms, IsVoid)
        VALUES (source.PropertyID, source.PropertyName, source.PropertyType,
                source.Address1, source.Address2, source.Town, source.PostCode,
                source.Bedrooms, source.IsVoid);

    PRINT 'Properties loaded. Valid: '
        + CAST((SELECT COUNT(*) FROM stg.Properties WHERE BatchID=@BatchID AND StgStatus='VALID') AS NVARCHAR)
        + ' | Rejected: '
        + CAST((SELECT COUNT(*) FROM stg.Properties WHERE BatchID=@BatchID AND StgStatus='REJECTED') AS NVARCHAR);
END;
GO

-- -------------------------------------------------------
-- usp_ValidateAndLoadRent
-- -------------------------------------------------------
CREATE OR ALTER PROCEDURE etl.usp_ValidateAndLoadRent
    @BatchID UNIQUEIDENTIFIER
AS
BEGIN
    SET NOCOUNT ON;

    -- Mark invalid
    UPDATE stg.Rent
    SET StgStatus = 'REJECTED'
    WHERE BatchID = @BatchID
      AND (
          TRY_CAST(PropertyID AS INT) IS NULL
          OR TRY_CAST(TenantID AS INT) IS NULL
          OR TRY_CAST(RentAmount AS DECIMAL(10,2)) IS NULL
          OR TRY_CAST(RentAmount AS DECIMAL(10,2)) <= 0
          OR TRY_CAST(RentDate AS DATE) IS NULL
          OR TRY_CAST(RentDate AS DATE) > CAST(GETDATE() AS DATE)
      );

    UPDATE stg.Rent
    SET StgStatus = 'VALID'
    WHERE BatchID = @BatchID AND StgStatus = 'PENDING';

    -- Insert valid records (avoid duplicates)
    INSERT INTO dbo.Rent (PropertyID, TenantID, RentAmount, RentDate, PaymentMethod, Notes)
    SELECT
        CAST(r.PropertyID AS INT),
        CAST(r.TenantID AS INT),
        CAST(r.RentAmount AS DECIMAL(10,2)),
        CAST(r.RentDate AS DATE),
        r.PaymentMethod,
        r.Notes
    FROM stg.Rent r
    WHERE r.BatchID = @BatchID
      AND r.StgStatus = 'VALID'
      -- Prevent duplicate rent entries for same property+tenant+date
      AND NOT EXISTS (
          SELECT 1 FROM dbo.Rent p
          WHERE p.PropertyID = CAST(r.PropertyID AS INT)
            AND p.TenantID   = CAST(r.TenantID AS INT)
            AND p.RentDate   = CAST(r.RentDate AS DATE)
      );

END;
GO

PRINT 'Validation stored procedures created.';
